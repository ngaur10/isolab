# Copy this file to .env and fill in your own values
# NEVER commit the actual .env file - it is blocked by .gitignore

# Required: Public IP of your OpenVPN EC2 server
# Get it from: AWS Console -> EC2 -> Instances -> lab-vpn-server -> Public IPv4
VPN_SERVER_IP=your-vpn-server-public-ip-here

# AWS credentials (recommended: use 'aws configure' instead)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_DEFAULT_REGION=eu-north-1
